# Local default: file:./data/aisle.db. Use libsql://... for Turso-compatible hosting.
DATABASE_URL=file:./data/aisle.db
DATABASE_AUTH_TOKEN=

# Public canonical origin used for metadata. Local development falls back to localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Reserved server-only token for authenticated scheduled catalog ingestion.
# Never expose this with a NEXT_PUBLIC_ prefix.
CATALOG_SYNC_TOKEN=

# skills.sh uses Vercel OIDC when available. Use only a short-lived local override here.
SKILLS_SH_OIDC_TOKEN=

# Optional public GitHub API token for higher rate limits. Do not grant private-repository access.
GITHUB_TOKEN=

# Explicitly opt AgentSkills.in into catalog synchronization. Enabling requires GITHUB_TOKEN
# because every registry identity is rebound to an exact public GitHub repository and SKILL.md.
AISLE_AGENTSKILLS_IN_ENABLED=false

# Explicitly opt AskSkill into partial federated discovery. Enabling requires GITHUB_TOKEN;
# provider rows only nominate exact public GitHub repositories and SKILL.md paths.
AISLE_ASKSKILL_ENABLED=false

# Explicitly opt into GetSkillary's bounded selected-public snapshot. This source
# records coverage-only observations and never downloads or installs provider ZIPs.
AISLE_GETSKILLARY_ENABLED=false

# Explicitly opt into bounded, always-partial GitHub Code Search discovery.
# Enabling requires GITHUB_TOKEN. The connector always searches the required
# SKILL.md metadata terms "name" and "description".
AISLE_GITHUB_CODE_SEARCH_ENABLED=false

# Optional comma-separated plain-text query terms added to the two fixed metadata
# queries. At most six additions are accepted; raw qualifiers/operators are rejected.
AISLE_GITHUB_CODE_SEARCH_QUERIES=

# Optional comma-separated public GitHub repository URLs that extend Aisle's
# normalized, deduplicated default discovery inventory, for example:
# https://github.com/example/agent-skills,https://github.com/example/more-skills
AISLE_GITHUB_REPOSITORIES=

# Comma-separated HTTPS origins approved for well-known discovery.
# These remain disabled and not-configured until transport is IP-pinned or egress-contained;
# setting this value alone never enables hostname fetching.
AISLE_WELL_KNOWN_ORIGINS=
