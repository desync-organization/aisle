# Local default: file:./data/aisle.db. Use libsql://... for Turso-compatible hosting.
DATABASE_URL=file:./data/aisle.db
DATABASE_AUTH_TOKEN=

# Public canonical origin used for metadata. Local development falls back to localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Reserved server-only token for authenticated scheduled catalog ingestion.
# Never expose this with a NEXT_PUBLIC_ prefix.
CATALOG_SYNC_TOKEN=

# skills.sh uses Vercel OIDC when available. Use only a short-lived local override here.
SKILLS_SH_OIDC_TOKEN=

# Optional public GitHub API token for higher rate limits. Do not grant private-repository access.
GITHUB_TOKEN=

# Comma-separated public GitHub repository URLs to inspect, for example:
# https://github.com/example/agent-skills,https://github.com/example/more-skills
AISLE_GITHUB_REPOSITORIES=

# Comma-separated HTTPS origins approved for well-known discovery.
# These remain disabled and not-configured until transport is IP-pinned or egress-contained;
# setting this value alone never enables hostname fetching.
AISLE_WELL_KNOWN_ORIGINS=
