# Optional until the catalog database work lands. Keep this file aligned with lib/env.ts.
DATABASE_URL=

# Public canonical origin used for metadata. Local development falls back to localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only token used by scheduled catalog ingestion in a later milestone.
# Never expose this with a NEXT_PUBLIC_ prefix.
CATALOG_SYNC_TOKEN=
