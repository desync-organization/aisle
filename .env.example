# Local default: file:./data/aisle.db. Use libsql://... for Turso-compatible hosting.
DATABASE_URL=file:./data/aisle.db
DATABASE_AUTH_TOKEN=

# Public canonical origin used for metadata. Local development falls back to localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only token used by scheduled catalog ingestion in a later milestone.
# Never expose this with a NEXT_PUBLIC_ prefix.
CATALOG_SYNC_TOKEN=

# Optional short-lived local fallback for skills.sh when Vercel OIDC is unavailable.
SKILLS_SH_TOKEN=
